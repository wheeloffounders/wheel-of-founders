{
  "name": "wheel-of-founders",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=4096 NEXT_PUBLIC_APP_ENV=development next dev -p 3000",
    "build": "next build",
    "vercel-build": "node scripts/validate-env.js && next build",
    "validate-env": "node scripts/validate-env.js",
    "preview:sync": "./scripts/fix-preview-supabase-env.sh",
    "sync:envs": "./scripts/sync-all-envs.sh",
    "dev-deploy": "npm run preview:sync && ./scripts/deploy-dev.sh",
    "build:dev": "NEXT_PUBLIC_APP_ENV=development next build",
    "build:prod": "NEXT_PUBLIC_APP_ENV=production next build",
    "start": "next start",
    "deploy:dev": "./scripts/deploy-dev.sh",
    "deploy:prod": "./scripts/deploy-prod.sh",
    "version:bump": "node scripts/version-bump.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "snyk:test": "snyk test",
    "snyk:monitor": "snyk monitor",
    "security:check": "npm run snyk:test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@mailerlite/mailerlite-nodejs": "^1.5.0",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.34.2",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "posthog-js": "^1.347.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-joyride": "^2.9.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-breaks": "^4.0.0",
    "stripe": "^17.3.1",
    "swr": "^2.4.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "snyk": "^1.1303.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^50.28.0"
  }
}
